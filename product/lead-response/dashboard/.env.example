# AI Lead Response System - Environment Configuration
# Copy this file to .env.local and fill in your values

# ============================================
# Supabase (Required)
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================
# Anthropic / Claude AI (Required)
# ============================================
ANTHROPIC_API_KEY=your-anthropic-api-key

# ============================================
# Twilio (Required for SMS)
# ============================================
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER_US=+1XXXXXXXXXX
TWILIO_PHONE_NUMBER_CA=+1XXXXXXXXXX
# Set to true for testing without sending real SMS
TWILIO_MOCK_MODE=false

# ============================================
# Follow Up Boss (Required for CRM sync)
# ============================================
FUB_API_KEY=your-fub-api-key
FUB_WEBHOOK_SECRET=your-fub-webhook-secret
FUB_API_BASE_URL=https://api.followupboss.com/v1

# ============================================
# Cal.com (Required for booking)
# ============================================
CALCOM_API_KEY=your-calcom-api-key
CALCOM_EVENT_TYPE_ID=your-event-type-id
CALCOM_BASE_URL=https://api.cal.com/v1
NEXT_PUBLIC_CALCOM_URL=https://cal.com

# ============================================
# Application
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ============================================
# Optional: Analytics & Monitoring
# ============================================
# SENTRY_DSN=your-sentry-dsn
# POSTHOG_KEY=your-posthog-key
