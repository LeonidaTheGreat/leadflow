  "codebase_rules": [
    {
      "id": "no-supabase-imports",
      "name": "No direct Supabase SDK imports",
      "pattern": "from '@supabase/supabase-js'|from \"@supabase/supabase-js\"|require\\('@supabase",
      "scan_dirs": [
        "product/lead-response/dashboard/app/",
        "product/lead-response/dashboard/lib/"
      ],
      "severity": "critical",
      "description": "All DB access must go through lib/db.ts PostgREST client, not Supabase SDK",
      "check": "(grep -rn \"from '@supabase/supabase-js'\\|from \\\"@supabase/supabase-js\\\"\\|require('@supabase\" product/lead-response/dashboard/app/ product/lead-response/dashboard/lib/ 2>/dev/null | grep -v '\\.test\\.\\|\\.spec\\.\\|__tests__') || true",
      "expected": ""
    },
    {
      "id": "no-supabase-env-vars",
      "name": "No Supabase env var references",
      "pattern": "NEXT_PUBLIC_SUPABASE_URL|NEXT_PUBLIC_SUPABASE_ANON_KEY|SUPABASE_URL|SUPABASE_SERVICE_ROLE_KEY",
      "scan_dirs": [
        "product/lead-response/dashboard/app/",
        "product/lead-response/dashboard/lib/"
      ],
      "exclude_patterns": [
        "*.test.*",
        "*.spec.*",
        "__tests__/"
      ],
      "severity": "critical",
      "description": "Supabase is removed. Use NEXT_PUBLIC_API_URL and API_SECRET_KEY",
      "check": "(grep -rn 'NEXT_PUBLIC_SUPABASE_URL\\|NEXT_PUBLIC_SUPABASE_ANON_KEY\\|SUPABASE_URL\\|SUPABASE_SERVICE_ROLE_KEY' product/lead-response/dashboard/app/ product/lead-response/dashboard/lib/ 2>/dev/null | grep -v '\\.test\\.\\|\\.spec\\.\\|__tests__') || true",
      "expected": ""
    },
    {
      "id": "no-supabase-deps",
      "name": "No Supabase packages in dependencies",
      "pattern": "@supabase/supabase-js|@supabase/ssr|@supabase/auth-helpers",
      "scan_dirs": [
        "product/lead-response/dashboard/"
      ],
      "scan_files": [
        "package.json"
      ],
      "severity": "critical",
      "description": "Supabase packages must not be in package.json",
      "check": "(grep -n '@supabase/supabase-js\\|@supabase/ssr\\|@supabase/auth-helpers' product/lead-response/dashboard/package.json 2>/dev/null) || true",
      "expected": ""
    },
    {
      "id": "build-passes",
      "name": "Next.js build passes",
      "check_type": "build",
      "command": "cd product/lead-response/dashboard && npx next build",
      "severity": "critical",
      "interval_hours": 24,
      "description": "Dashboard must build without errors",
      "check": "cd product/lead-response/dashboard && npx next build",
      "expected": ""
    }
  ]
