# PostHog Configuration
# Get your API key from https://app.posthog.com/project/settings

VITE_POSTHOG_API_KEY=phc_your_project_api_key_here
VITE_POSTHOG_HOST=https://app.posthog.com

# Google Analytics 4 (UC-LANDING-ANALYTICS-GA4-001)
# Stojan: create a GA4 property at analytics.google.com, then set this in Vercel env vars
# If not set, GA4 script will not load (graceful fallback — no console errors)
VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Set to 'true' to disable GA4 in local development (optional)
VITE_GA4_DISABLE_DEV=false
