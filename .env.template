# AI Lead Response System - Environment Configuration
# SECURITY: This template shows required variables. 
# Create .env file (NEVER commit to git) with actual values.

# ===== FOLLOW UP BOSS (FUB) =====
FUB_API_KEY=your_api_key_here_from_stojan
FUB_API_BASE_URL=https://api.followupboss.com/v1
FUB_WEBHOOK_SECRET=webhook_secret_for_request_verification

# ===== TWILIO (SMS PROVIDER) =====
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER_US=+1-xxx-xxx-xxxx
TWILIO_PHONE_NUMBER_CA=+1-xxx-xxx-xxxx

# ===== MARKET & DEPLOYMENT =====
MARKET_CONFIG=ca-ontario
NODE_ENV=development
PORT=3000

# ===== DATABASE =====
DATABASE_URL=postgres://user:password@localhost:5432/fub_lead_response
REDIS_URL=redis://localhost:6379

# ===== LOGGING & MONITORING =====
LOG_LEVEL=info
SENTRY_DSN=optional_error_tracking_url

# ===== FEATURE FLAGS =====
ENABLE_SMS=true
ENABLE_EMAIL=false
ENABLE_AUDIT_LOGGING=true
ENABLE_COMPLIANCE_CHECKS=true
