## Usage Example

```javascript
// Example: Accessing wizard copy
const wizardCopy = uiCopy.wizard.step_1_fub;

// Example: Getting trial banner text
function getTrialBanner(daysRemaining) {
  if (daysRemaining <= 1) {
    return uiCopy.trial_banner.day_14.text.replace('{{days_remaining}}', daysRemaining);
  } else if (daysRemaining <= 3) {
    return uiCopy.trial_banner.days_11_to_13.text.replace('{{days_remaining}}', daysRemaining);
  } else {
    return uiCopy.trial_banner.days_1_to_10.text.replace('{{days_remaining}}', daysRemaining);
  }
}

// Example: Error message lookup
function getErrorMessage(errorType, code) {
  return uiCopy.error_messages[errorType][code] || uiCopy.error_messages.generic.description;
}
```

