# Resend API Configuration
# Get your API key from: https://resend.com/api-keys

RESEND_API_KEY=re_your_api_key_here
RESEND_AUDIENCE_ID=leadflow-pilot

# Test Mode (set to 'true' to send to test addresses only)
TEST_MODE=true

# From Address (must be verified in Resend)
FROM_EMAIL=pilot@leadflow.ai
FROM_NAME=LeadFlow Pilot Team

# Reply-To Address
REPLY_TO=support@leadflow.ai

# Application URLs
APP_URL=https://app.leadflow.ai
API_URL=https://api.leadflow.ai

# Test Recipients (comma-separated)
TEST_RECIPIENTS=test-agent-1@leadflow.ai,test-agent-2@leadflow.ai,test-agent-3@leadflow.ai
